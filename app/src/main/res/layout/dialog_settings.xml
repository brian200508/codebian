<?xml version="1.0" encoding="utf-8"?>
<!-- Root: a scrollable settings body plus a persistent 4-button footer bar
     (Default / Revert / Cancel / Apply), used by SettingsDialog.kt. Kept as
     a plain LinearLayout (not AlertDialog's built-in positive/negative/
     neutral buttons) because we need four independent actions, which
     AlertDialog.Builder cannot express with only three button slots. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:maxHeight="480dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/settingsSectionDisplay"
                style="@style/TextAppearance.AppCompat.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textStyle="bold"
                android:text="@string/settings_section_display" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_theme" />

                <Spinner
                    android:id="@+id/themeSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_fullscreen" />

                <Switch
                    android:id="@+id/fullscreenSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:id="@+id/settingsSectionKeysBar"
                style="@style/TextAppearance.AppCompat.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:textStyle="bold"
                android:text="@string/settings_section_keys_bar" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_show_keys_bar" />

                <Switch
                    android:id="@+id/showKeysBarSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_height" />

                <Spinner
                    android:id="@+id/heightSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_key_width" />

                <Spinner
                    android:id="@+id/keyWidthSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:id="@+id/settingsSectionRemoteAccess"
                style="@style/TextAppearance.AppCompat.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:textStyle="bold"
                android:text="@string/settings_section_remote_access" />

            <TextView
                android:id="@+id/settingsSectionExposure"
                style="@style/TextAppearance.AppCompat.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textStyle="bold"
                android:text="@string/settings_section_exposure" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="@string/settings_exposure_caption"
                android:textSize="12sp" />

            <CheckBox
                android:id="@+id/exposureHomeCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_label_exposure_home" />

            <CheckBox
                android:id="@+id/exposureWorkspaceCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_label_exposure_workspace" />

            <CheckBox
                android:id="@+id/exposureSharedCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_label_exposure_shared" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:hintEnabled="true"
                android:hint="@string/settings_label_exposure_include">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/exposureIncludeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:hintEnabled="true"
                android:hint="@string/settings_label_exposure_exclude">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/exposureExcludeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/refreshExposureButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_btn_refresh_exposure" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/remoteAccessTabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                style="@style/Widget.CoDebian.TabLayout"
                app:tabMode="fixed"
                app:tabGravity="fill">

                <com.google.android.material.tabs.TabItem
                    android:text="@string/settings_tab_ssh" />

                <com.google.android.material.tabs.TabItem
                    android:text="@string/settings_tab_mcp" />

                <com.google.android.material.tabs.TabItem
                    android:text="@string/settings_tab_code_server" />
            </com.google.android.material.tabs.TabLayout>

            <LinearLayout
                android:id="@+id/sshTabContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_ssh_server" />

                <Switch
                    android:id="@+id/sshServerSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_ssh_port" />

                <EditText
                    android:id="@+id/sshPortEditText"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="5"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_sftp_port" />

                <EditText
                    android:id="@+id/sftpPortEditText"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="5"
                    android:gravity="end" />
            </LinearLayout>

            <Button
                android:id="@+id/copySshCommandButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_btn_copy_ssh_command" />

            <TextView
                android:id="@+id/sshConnectionInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:textIsSelectable="true"
                android:textSize="12sp" />

            <Button
                android:id="@+id/copySftpCommandButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/settings_btn_copy_sftp_command" />

            <TextView
                android:id="@+id/sftpConnectionInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:textIsSelectable="true"
                android:textSize="12sp" />

            <Button
                android:id="@+id/copySshResetCommandButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_btn_copy_ssh_reset_command" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:text="@string/settings_ssh_reset_command_caption"
                android:textSize="12sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/sshCustomPasswordLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:endIconMode="password_toggle"
                    app:hintEnabled="true"
                    android:hint="@string/settings_label_ssh_custom_password">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/sshCustomPasswordEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/generateSshPasswordButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="48dp"
                    android:layout_marginTop="2dp"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_dice"
                    android:contentDescription="@string/generate_ssh_password_content_description" />
            </FrameLayout>

            <Button
                android:id="@+id/copySshPasswordButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_btn_copy_ssh_password" />

            <Button
                android:id="@+id/openTermuxButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_btn_open_termux" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mcpTabContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="@string/settings_mcp_caption"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_mcp_server" />

                <Switch
                    android:id="@+id/mcpServerSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_mcp_port" />

                <EditText
                    android:id="@+id/mcpPortEditText"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="5"
                    android:gravity="end" />
            </LinearLayout>

            <Button
                android:id="@+id/copyMcpUrlButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_btn_copy_mcp_url" />

            <TextView
                android:id="@+id/mcpConnectionInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:textIsSelectable="true"
                android:textSize="12sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/mcpCustomApiKeyLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:endIconMode="password_toggle"
                    app:hintEnabled="true"
                    android:hint="@string/settings_label_mcp_custom_key">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/mcpCustomApiKeyEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/generateMcpApiKeyButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="48dp"
                    android:layout_marginTop="2dp"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_dice"
                    android:contentDescription="@string/generate_mcp_key_content_description" />
            </FrameLayout>

            <Button
                android:id="@+id/copyMcpApiKeyButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_btn_copy_mcp_key" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/codeServerTabContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="@string/settings_code_server_caption"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_code_server_port" />

                <EditText
                    android:id="@+id/codeServerPortEditText"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="5"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_label_code_server_auth" />

                <Switch
                    android:id="@+id/codeServerAuthSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/copyCodeServerUrlButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_btn_copy_code_server_url" />

            <TextView
                android:id="@+id/codeServerConnectionInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:textIsSelectable="true"
                android:textSize="12sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/codeServerCustomPasswordLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:endIconMode="password_toggle"
                    app:hintEnabled="true"
                    android:hint="@string/settings_label_code_server_custom_password">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/codeServerCustomPasswordEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/generateCodeServerPasswordButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="48dp"
                    android:layout_marginTop="2dp"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_dice"
                    android:contentDescription="@string/generate_code_server_password_content_description" />
            </FrameLayout>

            <Button
                android:id="@+id/copyCodeServerPasswordButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_btn_copy_code_server_password" />
            </LinearLayout>

            <TextView
                android:id="@+id/settingsSectionBackup"
                style="@style/TextAppearance.AppCompat.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:textStyle="bold"
                android:text="@string/settings_section_backup" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="@string/settings_backup_caption"
                android:textSize="12sp" />

            <Button
                android:id="@+id/exportConfigButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_btn_export_config" />

            <Button
                android:id="@+id/importConfigButton"
                style="@style/Widget.CoDebian.Button.DialogAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_btn_import_config" />

        </LinearLayout>
    </ScrollView>

    <!-- Equal-weight row so 4 outlined buttons (each now with a visible
         border + inset padding, wider than the old flat text buttons)
         always fit the row width instead of the last one (Save) being
         clipped off-screen edge-to-edge. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <Button
            android:id="@+id/settingsDefaultButton"
            style="@style/Widget.CoDebian.Button.DialogAction.Compact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_btn_default" />

        <Button
            android:id="@+id/settingsRevertButton"
            style="@style/Widget.CoDebian.Button.DialogAction.Compact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/settings_btn_revert" />

        <Button
            android:id="@+id/settingsCancelButton"
            style="@style/Widget.CoDebian.Button.DialogAction.Compact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/settings_btn_cancel" />

        <Button
            android:id="@+id/settingsApplyButton"
            style="@style/Widget.CoDebian.Button.DialogAction.Compact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/settings_btn_save" />

    </LinearLayout>

</LinearLayout>
